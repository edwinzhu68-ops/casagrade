# 服务端口（默认 3000）
PORT=3000

# 生产环境请设置，避免自动改表
# NODE_ENV=production

# 数据库文件路径（默认 lottery.db）
# DATABASE_PATH=./data/lottery.db

# 管理员密钥：总后台开奖/结算/店铺对比等接口需在请求头带 X-Admin-Token 与此值一致
# 不设置则不做校验（便于本地开发）
# ADMIN_TOKEN=your-secret-admin-token

# 允许的跨域来源，多个用英文逗号分隔；不设置则默认允许 www/api.casagrade.com 及 localhost
# 顾客端在 www 域名下访问时，必须允许 https://www.casagrade.com
# ALLOWED_ORIGINS=https://www.casagrade.com,https://api.casagrade.com
