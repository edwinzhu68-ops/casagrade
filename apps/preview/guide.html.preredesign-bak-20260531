    function openPoster() {
      const token = localStorage.getItem('lottery_token');
      const shopNumber = localStorage.getItem('lottery_shop_number');
      if (!token || !shopNumber) {
        // 未登录：提示并跳转
        const hint = document.getElementById('poster-hint');
        if (hint) { hint.classList.remove('hidden'); }
        setTimeout(() => { window.location.href = 'merchant.html'; }, 1200);
        return;
      }
      window.open('poster.html?shop=' + encodeURIComponent(shopNumber), '_blank');
    }

    function toggleLang() {
      lang = lang === 'zh' ? 'es' : 'zh';
      localStorage.setItem('guide_lang', lang);
      applyLang();
    }

